# ============================================================
#  .gitignore for plant-companion-server
# ============================================================

# Dependencies (never commit — too large)
node_modules/

# Compiled output (regenerated by: npm run build)
dist/

# Environment variables — NEVER commit .env
# It contains secrets like your database password and JWT keys
.env*

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db
